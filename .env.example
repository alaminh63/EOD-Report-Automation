# ============================================================
# DDR — Daily Report Automation
# Copy this file to .env and fill in your values
# ============================================================

# ── Google Account ──────────────────────────────────────────
# OAuth credentials file path (default: config/credentials.json)
# Download from: console.cloud.google.com → APIs → Credentials → OAuth client → Desktop app
GOOGLE_CREDENTIALS_FILE=config/credentials.json

# OAuth token cache path (auto-created on first login)
GOOGLE_TOKEN_FILE=config/token.json

# ── Google Doc ──────────────────────────────────────────────
# Doc ID from URL: docs.google.com/document/d/<DOC_ID>/edit
# Also configurable in data/templates.json (takes priority)
GOOGLE_DOC_ID=your_google_doc_id_here

# ── Google Chat ─────────────────────────────────────────────
# Space ID from URL: chat.google.com → space → copy ID
# Format: spaces/XXXXXXXXX
GOOGLE_CHAT_SPACE=spaces/your_space_id_here

# ── OpenRouter (AI task formatting) ─────────────────────────
# API key from: openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your_key_here

# Preferred model — tried first, then falls back to free chain
# Leave empty to use default free chain
# Browse: openrouter.ai/models?q=free
# Options:
#   google/gemini-2.0-flash-exp:free      (default first in chain)
#   google/gemini-flash-1.5-8b-exp:free
#   meta-llama/llama-3.1-8b-instruct:free
#   mistralai/mistral-7b-instruct:free
#   microsoft/phi-3-mini-128k-instruct:free
#   openchat/openchat-7b:free
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# ── Project settings (override data/project.json) ───────────
# Uncomment to override without editing JSON files
# PROJECT_NAME=Cloud Platform
# DEVELOPER_NAME=MD Al Amin Hasan
# DEVELOPER_ROLE=Full Stack Developer
# COMPANY_NAME=Cloud Gen
# PROJECT_START_DATE=2026-06-17
