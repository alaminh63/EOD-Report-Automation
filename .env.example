# ── Google Doc ────────────────────────────────────────────────────────────────
# Google Doc ID from URL: docs.google.com/document/d/DOC_ID/edit
GOOGLE_DOC_ID=your_google_doc_id_here

# ── Google Chat ────────────────────────────────────────────────────────────────
# Space ID from Chat URL: chat.google.com/app/chat/SPACE_ID
# Format: spaces/SPACE_ID
GOOGLE_CHAT_SPACE=spaces/your_space_id_here

# ── Project Info ───────────────────────────────────────────────────────────────
PROJECT_NAME=Your Project Name
PROJECT_START_DATE=YYYY-MM-DD
DEVELOPER_NAME=Your Full Name
DEVELOPER_ROLE=Your Role
COMPANY_NAME=Your Company
